  "keyFeatures": [
    "Expressive, type-safe routing with path parameters",
    "Async/await and SwiftNIO-based concurrency",
    "Built-in middleware system (CORS, compression, error handling)",
    "Codable-based request/response content encoding (JSON, multipart, URL-encoded form)",
    "WebSocket support",
    "Session management with pluggable drivers",
    "Authentication helpers (Basic, Bearer, session-based)",
    "Input validation framework",
    "HTTP/1 and HTTP/2 support with TLS via SwiftNIO",
    "Built-in Bcrypt password hashing",
    "Structured logging and distributed tracing",
    "Environment-based configuration with secret support"
  ],
  "publicApiSurface": [
    "Application",
    "RoutesBuilder (get, post, put, patch, delete, on)",
    "RouteCollection",
    "Request",
    "Response",
    "Middleware",
    "Content / ResponseEncodable / RequestDecodable",
    "Authenticator / BasicAuthenticator / BearerAuthenticator",
    "SessionsMiddleware / Session",
    "Validations / Validator",
    "Environment",
    "CORSMiddleware",
    "FileMiddleware",
    "ErrorMiddleware",
    "WebSocket (via RoutesBuilder+WebSocket)",
    "VaporTesting / XCTVapor (test helpers)"
  ]
